<Window x:Class="lab3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:lab3.ViewModels"
        Title="💖 Розовый Калькулятор MVVM" Height="450" Width="550"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:CalculatorViewModel/>
    </Window.DataContext>

    <Grid Background="#FFB6C1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="5"/>
        </Grid.ColumnDefinitions>

        <!-- === КАЛЬКУЛЯТОР (слева) === -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Экран вывода -->
            <TextBox Grid.Row="0" Text="{Binding Display, Mode=OneWay}" 
                     Background="#FFF0F5" Foreground="#C71585" 
                     FontSize="36" TextAlignment="Right" 
                     VerticalContentAlignment="Center"
                     BorderThickness="0" IsReadOnly="True" Margin="10"
                     FontFamily="Segoe UI"/>

            <!-- Кнопки -->
            <Grid Grid.Row="1" Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <!-- Розовые стили кнопок -->
                <Grid.Resources>
                    <Style TargetType="Button">
                        <Setter Property="FontSize" Value="20"/>
                        <Setter Property="Margin" Value="3"/>
                        <Setter Property="Background" Value="#FF69B4"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF1493"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#C71585"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                    <Style x:Key="OperatorButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Background" Value="#FF1493"/>
                    </Style>
                    <Style x:Key="FunctionButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Background" Value="#DB7093"/>
                        <Setter Property="Foreground" Value="White"/>
                    </Style>
                    <Style x:Key="EqualsButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Background" Value="#C71585"/>
                    </Style>
                </Grid.Resources>

                <!-- 1 Ряд: Функциональные кнопки -->
                <Button Content="C" Grid.Row="0" Grid.Column="0" Style="{StaticResource FunctionButton}" 
                        Command="{Binding ClearCommand}"/>
                <Button Content="±" Grid.Row="0" Grid.Column="1" Style="{StaticResource FunctionButton}" 
                        Command="{Binding NegateCommand}"/>
                <Button Content="%" Grid.Row="0" Grid.Column="2" Style="{StaticResource FunctionButton}" 
                        Command="{Binding PercentCommand}"/>
                <Button Content="÷" Grid.Row="0" Grid.Column="3" Style="{StaticResource OperatorButton}" 
                        Command="{Binding OperatorCommand}" CommandParameter="/"/>

                <!-- 2 Ряд: 7-9 и умножение -->
                <Button Content="7" Grid.Row="1" Grid.Column="0" Command="{Binding NumberCommand}" CommandParameter="7"/>
                <Button Content="8" Grid.Row="1" Grid.Column="1" Command="{Binding NumberCommand}" CommandParameter="8"/>
                <Button Content="9" Grid.Row="1" Grid.Column="2" Command="{Binding NumberCommand}" CommandParameter="9"/>
                <Button Content="×" Grid.Row="1" Grid.Column="3" Style="{StaticResource OperatorButton}" 
                        Command="{Binding OperatorCommand}" CommandParameter="*"/>

                <!-- 3 Ряд: 4-6 и вычитание -->
                <Button Content="4" Grid.Row="2" Grid.Column="0" Command="{Binding NumberCommand}" CommandParameter="4"/>
                <Button Content="5" Grid.Row="2" Grid.Column="1" Command="{Binding NumberCommand}" CommandParameter="5"/>
                <Button Content="6" Grid.Row="2" Grid.Column="2" Command="{Binding NumberCommand}" CommandParameter="6"/>
                <Button Content="−" Grid.Row="2" Grid.Column="3" Style="{StaticResource OperatorButton}" 
                        Command="{Binding OperatorCommand}" CommandParameter="-"/>

                <!-- 4 Ряд: 1-3 и сложение -->
                <Button Content="1" Grid.Row="3" Grid.Column="0" Command="{Binding NumberCommand}" CommandParameter="1"/>
                <Button Content="2" Grid.Row="3" Grid.Column="1" Command="{Binding NumberCommand}" CommandParameter="2"/>
                <Button Content="3" Grid.Row="3" Grid.Column="2" Command="{Binding NumberCommand}" CommandParameter="3"/>
                <Button Content="+" Grid.Row="3" Grid.Column="3" Style="{StaticResource OperatorButton}" 
                        Command="{Binding OperatorCommand}" CommandParameter="+"/>

                <!-- 5 Ряд: 0, запятая, равно -->
                <Button Content="0" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" 
                        Command="{Binding NumberCommand}" CommandParameter="0"/>
                <Button Content="," Grid.Row="4" Grid.Column="2" Command="{Binding NumberCommand}" CommandParameter=","/>
                <Button Content="=" Grid.Row="4" Grid.Column="3" Style="{StaticResource EqualsButton}" 
                        Command="{Binding EqualsCommand}"/>
            </Grid>
        </Grid>

        <!-- === ИСТОРИЯ (справа) === -->
        <Grid Grid.Column="1" Background="#FFC0CB">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="💕 История" Foreground="#C71585" FontSize="18" FontWeight="Bold" 
                       VerticalAlignment="Center" HorizontalAlignment="Center"/>

            <!-- Список истории -->
            <ListBox Grid.Row="1" ItemsSource="{Binding History}" 
                     Background="#FFF0F5" Foreground="#C71585" BorderThickness="0" FontSize="14">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="5">
                            <TextBlock Text="{Binding Expression}" Foreground="#DB7093" FontSize="12"/>
                            <TextBlock Text="{Binding Result}" Foreground="#FF1493" FontSize="16" FontWeight="Bold"/>
                            <Separator Background="#FFB6C1" Margin="0,5,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Кнопка очистки истории -->
            <Button Grid.Row="2" Content="🗑 Очистить" Background="#DB7093" Foreground="White"
                    BorderThickness="0" Margin="5" Command="{Binding ClearHistoryCommand}">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF69B4"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!-- Разделительная линия -->
        <Grid Grid.Column="2" Background="#FF69B4"/>
    </Grid>
</Window>