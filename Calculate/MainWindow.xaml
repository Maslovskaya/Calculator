<!-- 
    MainWindow.xaml - Это представление (View) нашего приложения.
    Здесь только визуальные элементы: кнопки, экран, панель истории.
    Никакой логики вычислений здесь нет - всё делегируется в код (C#).
    
    Используемые паттерны:
    - MVVM (частично): разделение интерфейса и логики
    - Grid Layout: сетка для расположения кнопок
-->

<Window x:Class="Calculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор (Паттерны)" Height="550" Width="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">

	<Grid Background="#000000">
		<!-- Разделяем окно на 2 части: калькулятор (слева) и история (справа) -->
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="3*"/>
			<!-- Калькулятор занимает 3 части -->
			<ColumnDefinition Width="1*"/>
			<!-- История занимает 1 часть -->
			<ColumnDefinition Width="5"/>
			<!-- Разделительная линия -->
		</Grid.ColumnDefinitions>

		<!-- === ЛЕВАЯ ЧАСТЬ: КАЛЬКУЛЯТОР === -->
		<Grid Grid.Column="0">
			<Grid.RowDefinitions>
				<RowDefinition Height="120"/>
				<!-- Экран -->
				<RowDefinition Height="*"/>
				<!-- Кнопки -->
			</Grid.RowDefinitions>

			<!-- Экран вывода результатов -->
			<TextBox x:Name="Display" Grid.Row="0" Background="#6d016c" Foreground="White"
					 FontSize="40" TextAlignment="Right" VerticalContentAlignment="Center"
					 BorderThickness="0" IsReadOnly="True" Margin="10"/>

			<!-- Сетка кнопок 5x4 (5 строк, 4 столбца) -->
			<Grid Grid.Row="1" Margin="5">
				<Grid.ColumnDefinitions>
					<ColumnDefinition/>
					<ColumnDefinition/>
					<ColumnDefinition/>
					<ColumnDefinition/>
				</Grid.ColumnDefinitions>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<!-- Строка 1: Undo + C + ± + % -->
					<RowDefinition/>
					<RowDefinition/>
					<RowDefinition/>
					<RowDefinition/>
				</Grid.RowDefinitions>

				<!-- Стили -->
				<Grid.Resources>
					<Style TargetType="Button">
						<Setter Property="FontSize" Value="20"/>
						<Setter Property="Margin" Value="3"/>
						<Setter Property="Background" Value="#3C3C3C"/>
						<Setter Property="Foreground" Value="White"/>
						<Setter Property="BorderThickness" Value="0"/>
						<Setter Property="Cursor" Value="Hand"/>
						<Style.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Background" Value="#505050"/>
							</Trigger>
						</Style.Triggers>
					</Style>
					<Style x:Key="OperatorButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
						<Setter Property="Background" Value="#FF9500"/>
					</Style>
					<Style x:Key="FunctionButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
						<Setter Property="Background" Value="#A5A5A5"/>
						<Setter Property="Foreground" Value="Black"/>
					</Style>
				</Grid.Resources>

				<!-- 1-я строка: Кнопка Undo (левая), затем C, ±, % -->
				<Button Content="⌫" Grid.Row="0" Grid.Column="0" Background="#f0dff2" Style="{StaticResource FunctionButton}" Click="Btn_Undo_Click" FontSize="20" Padding="5"/>
				<Button Content="C" Grid.Row="0" Grid.Column="1" Background="#f0dff2" Style="{StaticResource FunctionButton}" Click="Btn_Clear_Click" FontSize="20"/>
				<Button Content="±" Grid.Row="0" Grid.Column="2" Background="#f0dff2" Style="{StaticResource FunctionButton}" Click="Btn_Negate_Click" FontSize="20"/>
				<Button Content="%" Grid.Row="0" Grid.Column="3" Background="#f0dff2" Style="{StaticResource FunctionButton}" Click="Btn_Percent_Click" FontSize="20"/>

				<!-- 2-я строка: 7, 8, 9, ÷ -->
				<Button Content="7" Grid.Row="1" Grid.Column="0" Click="Btn_Number_Click" Background="#ffd0e6" Foreground="Black" FontSize="30"/>
				<Button Content="8" Grid.Row="1" Grid.Column="1" Click="Btn_Number_Click" Background="#ffd0e6" Foreground="Black" FontSize="30"/>
				<Button Content="9" Grid.Row="1" Grid.Column="2" Click="Btn_Number_Click" Background="#ffd0e6" Foreground="Black" FontSize="30"/>
				<Button Content="÷" Grid.Row="1" Grid.Column="3" Style="{StaticResource OperatorButton}" Click="Btn_Operator_Click" Tag="/" Background="#e04386" Foreground="White" FontSize="35"/>

				<!-- 3-я строка: 4, 5, 6, × -->
				<Button Content="4" Grid.Row="2" Grid.Column="0" Click="Btn_Number_Click" Background="#ffd0e6" Foreground="Black" FontSize="30"/>
				<Button Content="5" Grid.Row="2" Grid.Column="1" Click="Btn_Number_Click" Background="#ffd0e6" Foreground="Black" FontSize="30"/>
				<Button Content="6" Grid.Row="2" Grid.Column="2" Click="Btn_Number_Click" Background="#ffd0e6" Foreground="Black" FontSize="30"/>
				<Button Content="×" Grid.Row="2" Grid.Column="3" Style="{StaticResource OperatorButton}" Click="Btn_Operator_Click" Tag="*" Background="#e04386" Foreground="White" FontSize="35"/>

				<!-- 4-я строка: 1, 2, 3, − -->
				<Button Content="1" Grid.Row="3" Grid.Column="0" Click="Btn_Number_Click" Background="#ffd0e6" Foreground="Black" FontSize="30"/>
				<Button Content="2" Grid.Row="3" Grid.Column="1" Click="Btn_Number_Click" Background="#ffd0e6" Foreground="Black" FontSize="30"/>
				<Button Content="3" Grid.Row="3" Grid.Column="2" Click="Btn_Number_Click" Background="#ffd0e6" Foreground="Black" FontSize="30"/>
				<Button Content="−" Grid.Row="3" Grid.Column="3" Style="{StaticResource OperatorButton}" Click="Btn_Operator_Click" Tag="-" Background="#e04386" Foreground="White" FontSize="35"/>

				<!-- 5-я строка: 0, , , = -->
				<Button Content="0" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Click="Btn_Number_Click" Background="#ffd0e6" Foreground="Black" FontSize="30"/>
				<Button Content="," Grid.Row="4" Grid.Column="2" Click="Btn_Number_Click" Background="#ffd0e6" Foreground="Black" FontSize="30"/>
				<Button Content="=" Grid.Row="4" Grid.Column="3" Style="{StaticResource OperatorButton}" Click="Btn_Equals_Click" Background="#b4bd63" Foreground="White" FontSize="40"/>
			</Grid>
		</Grid>

		<!-- === ПРАВАЯ ЧАСТЬ: ИСТОРИЯ ВЫЧИСЛЕНИЙ === -->
		<Grid Grid.Column="1" Background="#6d016c" Cursor="Hand">
			<Grid.RowDefinitions>
				<RowDefinition Height="40"/>
				<!-- Заголовок -->
				<RowDefinition Height="*"/>
				<!-- Список истории -->
				<RowDefinition Height="40"/>
				<!-- Кнопка очистки -->
			</Grid.RowDefinitions>

			<TextBlock Grid.Row="0" Text="История" Foreground="White" FontSize="18" FontWeight="Bold"
                       VerticalAlignment="Center" HorizontalAlignment="Center"/>

			<!-- Список для отображения истории (использует DataBinding) -->
			<ListBox x:Name="HistoryList" Grid.Row="1" Background="#6d016c" Foreground="#CCCCCC"
                     BorderThickness="0" FontSize="14" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
				<ListBox.ItemTemplate>
					<DataTemplate>
						<StackPanel Margin="5">
							<!-- Выражение (серым цветом) -->
							<TextBlock Text="{Binding Expression}" Foreground="#888888" FontSize="12"/>
							<!-- Результат (оранжевым цветом) -->
							<TextBlock Text="{Binding Result}" Foreground="#FF9500" FontSize="16" FontWeight="Bold"/>
							<Separator Background="#444444" Margin="0,5,0,0"/>
						</StackPanel>
					</DataTemplate>
				</ListBox.ItemTemplate>
			</ListBox>

			<!-- Кнопка очистки истории -->
			<Button Grid.Row="2" Content="Очистить историю" Background="#A95993" Foreground="White"
                    BorderThickness="0" Margin="5" Click="Btn_ClearHistory_Click" FontSize="14">
				<Button.Style>
					<Style TargetType="Button">
						<Setter Property="Cursor" Value="Hand"/>
						<Style.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Background" Value="#666666"/>
							</Trigger>
						</Style.Triggers>
					</Style>
				</Button.Style>
			</Button>
		</Grid>

		<!-- Вертикальная разделительная линия -->
		<Grid Grid.Column="2" Background="#000000"/>
	</Grid>
</Window>